* Fix Mobile Vikings MNC code was not correct so link fot more info on the Mobile Vikings website.

https://support.mobilevikings.be/hc/nl/articles/202836041-Ik-heb-geen-mobiel-internet-Wat-moet-ik-doen
---
 serviceproviders.xml | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/serviceproviders.xml b/serviceproviders.xml
index 94c49170..77d7e58d 100644
--- a/serviceproviders.xml
+++ b/serviceproviders.xml
@@ -1494,11 +1494,12 @@ conceived.
 	<provider>
 		<name>Mobile Vikings</name>
 		<gsm>
-			<network-id mcc="206" mnc="20"/>
+			<network-id mcc="206" mnc="01"/>
 			<voicemail>1933</voicemail>
-			<apn value="web.be">
+			<apn value="internet.proximus.be">
 				<plan type="prepaid"/>
 				<usage type="internet"/>
+			        <name>Mobile Vikings Internet</name>
 				<username>web</username>
 				<password>web</password>
 			</apn>

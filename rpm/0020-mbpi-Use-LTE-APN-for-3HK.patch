From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Slava Monich <slava.monich@jolla.com>
Date: Wed, 14 May 2014 11:51:41 +0400
Subject: [PATCH] [mbpi] Use LTE APN for 3HK

---
 serviceproviders.xml | 11 +++++++----
 1 file changed, 7 insertions(+), 4 deletions(-)

diff --git a/serviceproviders.xml b/serviceproviders.xml
index a1bd904..264a1a5 100644
--- a/serviceproviders.xml
+++ b/serviceproviders.xml
@@ -5653,15 +5653,18 @@ conceived.
 	<provider>
 		<name>3</name>
 		<gsm>
+			<!-- http://www.three.com.hk/website/appmanager/three/home?_nfpb=true&pageid=b15201&lang=eng -->
 			<network-id mcc="454" mnc="03"/>
-			<apn value="mobile.three.com.hk">
+			<!-- 3G apn is "mobile.three.com.hk" -->
+			<apn value="mobile.lte.three.com.hk">
 				<plan type="postpaid"/>
 				<usage type="internet"/>
-				<name>3</name>
+				<name>3 (LTE)</name>
 			</apn>
-			<apn value="mobile.three.com.hk">
+			<!-- 3G apn is "mobile.three.com.hk" -->
+			<apn value="mobile.lte.three.com.hk">
 				<usage type="mms"/>
-				<name>3 MMS</name>
+				<name>3 MMS (LTE)</name>
 				<mmsc>http://mms.um.three.com.hk:10021/mmsc</mmsc>
 				<mmsproxy>172.20.97.116:8799</mmsproxy>
 			</apn>

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Martti Piirainen <martti.piirainen@oss.tieto.com>
Date: Sun, 11 May 2014 11:51:12 +0300
Subject: [PATCH] gb: Distiguish MNOs (primary providers) from MVNOs

Checked from http://www.ofcom.org.uk/static/numbering/#mnc
---
 serviceproviders.xml | 11 ++++++-----
 1 file changed, 6 insertions(+), 5 deletions(-)

diff --git a/serviceproviders.xml b/serviceproviders.xml
index 9b1acc35..cd593570 100644
--- a/serviceproviders.xml
+++ b/serviceproviders.xml
@@ -5287,7 +5287,7 @@ conceived.
 
 <!-- Britain -->
 <country code="gb">
-	<provider>
+	<provider primary="true">
 		<name>BT Mobile</name>
 		<gsm>
 			<network-id mcc="234" mnc="00"/>
@@ -5351,7 +5351,7 @@ conceived.
 			</apn>
 		</gsm>
 	</provider>
-	<provider>
+	<provider primary="true">
 		<name>O2</name>
 		<gsm>
 			<network-id mcc="234" mnc="02"/>
@@ -5440,10 +5440,11 @@ conceived.
 			</apn>
 		</gsm>
 	</provider>
-	<provider>
+	<provider primary="true">
 		<!-- http://sales.talktalk.co.uk/products/mobile/faq/started.html#A12 -->
 		<name>TalkTalk</name>
 		<gsm>
+			<network-id mcc="234" mnc="16"/>
 			<apn value="mobile.talktalk.co.uk">
 				<gateway>212.183.137.12:8799</gateway>
 				<username>wap</username>
@@ -5492,7 +5493,7 @@ conceived.
 			</apn>
 		</gsm>
 	</provider>
-	<provider>
+	<provider primary="true">
 		<name>Vodafone</name>
 		<gsm>
 			<network-id mcc="234" mnc="15"/>
@@ -5566,7 +5567,7 @@ conceived.
 			</apn>
 		</gsm>
 	</provider>
-	<provider>
+	<provider primary="true">
 		<name>3</name>
 		<gsm>
 			<network-id mcc="234" mnc="20"/>

+				<protocol type="ip"/>
+			</apn>
+			<apn value="mms.nuevatel.com">
+				<usage type="mms"/>
+				<name>Viva MMS</name>
+				<mmsc>http://mmsgw.nuevatel.com:1981</mmsc>
+				<mmsproxy>192.168.101.4:3128</mmsproxy>
+			</apn>
+		</gsm>
+	</provider>
+	<provider>
+		<name>Entel</name>
+		<gsm>
+			<network-id mcc="736" mnc="02"/>

From: atlochowski <hucul@o2.pl>
Date: Tue, 20 Dec 2016 22:59:01 +0000
Subject: [PATCH] Added RebBullMobile MVNO. MER#902

---
 serviceproviders.xml | 22 ++++++++++++++++++++--
 1 file changed, 20 insertions(+), 2 deletions(-)

diff --git a/serviceproviders.xml b/serviceproviders.xml
index f2eb8425e..6fabe362c 100644
--- a/serviceproviders.xml
+++ b/serviceproviders.xml
@@ -11259,7 +11259,7 @@ conceived.
 		</gsm>
 	</provider>
 	<!-- Polish MVNO operators -->
-	<provider primary="false">
+	<provider>
 		<name>Multimo</name>
 		<gsm>
 			<network-id mcc="260" mnc="03"/>
@@ -11328,7 +11328,25 @@ conceived.
 			</apn>
 		</gsm>
 	</provider>
-	<provider primary="false">
+	<provider>
+		<name>RedBullMobile</name>
+		<gsm>
+			<network-id mcc="260" mnc="06"/>
+			<balance-check>
+				<ussd>*101#</ussd>
+			</balance-check>
+			<balance-top-up>
+				<ussd replacement="CODE">*111*CODE#</ussd>
+			</balance-top-up>
+			<apn value="mms">
+				<usage type="mms"/>
+				<name>RedBullMobile MMS</name>
+				<mmsc>http://10.10.28.164/mms/wapenc</mmsc>
+				<mmsproxy>10.10.25.5:8080</mmsproxy>
+			</apn>
+		</gsm>
+	</provider>
+ 	<provider primary="false">
 		<name>Netia</name>
 		<gsm>
 			<network-id mcc="260" mnc="06"/>

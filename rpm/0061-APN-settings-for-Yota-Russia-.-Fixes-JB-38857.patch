From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Slava Monich <slava.monich@jolla.com>
Date: Fri, 2 Jun 2017 12:06:09 +0300
Subject: [PATCH] APN settings for Yota (Russia). Fixes JB#38857

---
 serviceproviders.xml | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/serviceproviders.xml b/serviceproviders.xml
index 60d203c2..3eeaf5d2 100644
--- a/serviceproviders.xml
+++ b/serviceproviders.xml
@@ -11440,6 +11440,23 @@ conceived.
 			</apn>
 		</gsm>
 	</provider>
+	<provider>
+		<name>YOTA</name>
+		<gsm>
+			<network-id mcc="250" mnc="11"/>
+			<network-id mcc="250" mnc="50"/>
+			<apn value="internet.yota">
+				<usage type="internet"/>
+				<name>YOTA Internet</name>
+			</apn>
+			<apn value="mms.yota">
+				<usage type="mms"/>
+				<name>YOTA MMS</name>
+				<mmsc>http://mmsc:8002</mmsc>
+				<mmsproxy>10.10.10.10:8080</mmsproxy>
+			</apn>
+		</gsm>
+	</provider>
 	<provider>
 		<name>Skylink</name>
 		<name xml:lang="ru">Скайлинк</name>

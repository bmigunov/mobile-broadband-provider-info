From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Denis Grigorev <d.grigorev@omprussia.ru>
Date: Mon, 1 Feb 2021 17:53:48 +0300
Subject: [PATCH] Add APN settings for ROSTELECOM (Russia). Fixes JB#53005

Rostelecom is a Tele2 RU -based MVNO.
---
 serviceproviders.xml | 23 ++++++++++++++++++++++-
 1 file changed, 22 insertions(+), 1 deletion(-)

diff --git a/serviceproviders.xml b/serviceproviders.xml
index 6c8d6c59..09f0666f 100644
--- a/serviceproviders.xml
+++ b/serviceproviders.xml
@@ -12282,7 +12282,7 @@ conceived.
 			</apn>
 		</gsm>
 	</provider>
-	<provider>
+	<provider primary="true">
 		<name>Tele2</name>
 		<name xml:lang="ru">Теле2</name>
 		<gsm>
@@ -12332,6 +12332,27 @@ conceived.
 			</apn>
 		</gsm>
 	</provider>
+	<provider>
+		<name>ROSTELECOM</name>
+		<name xml:lang="ru">Ростелеком</name>
+		<gsm>
+			<network-id mcc="250" mnc="20"/>
+			<balance-check>
+				<ussd>*102#</ussd>
+			</balance-check>
+			<apn value="internet.rtk.ru">
+				<plan type="postpaid"/>
+				<usage type="internet"/>
+				<name>ROSTELECOM</name>
+			</apn>
+			<apn value="mms.rtk.ru">
+				<usage type="mms"/>
+				<name>ROSTELECOM MMS</name>
+				<mmsc>http://mmsc.rtk.ru</mmsc>
+				<mmsproxy>193.12.40.65:8080</mmsproxy>
+			</apn>
+		</gsm>
+	</provider>
 	<provider>
 		<name>YOTA</name>
 		<gsm>

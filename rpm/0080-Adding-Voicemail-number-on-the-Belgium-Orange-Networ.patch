From: Rudi Timmermans <101011119+ruditimmermans@users.noreply.github.com>
Date: Wed, 7 Feb 2024 15:24:20 +0100
Subject: [PATCH] Adding Voicemail number on the Belgium Orange Network

---
 serviceproviders.xml | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/serviceproviders.xml b/serviceproviders.xml
index 6514e4572..b49cfcf95 100644
--- a/serviceproviders.xml
+++ b/serviceproviders.xml
@@ -1506,6 +1506,8 @@ conceived.
 		<name>Orange</name>
 		<gsm>
 			<network-id mcc="206" mnc="10"/>
+		        <voicemail>5555</voicemail>
+			<!-- no balancecheck method ('auto-recharge') -->
 			<apn value="mworld.be">
 				<plan type="postpaid"/>
 				<usage type="internet"/>

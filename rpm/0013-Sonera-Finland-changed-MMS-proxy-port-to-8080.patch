 serviceproviders.xml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/serviceproviders.xml b/serviceproviders.xml
index 5a9b7c09..4b091f77 100644
--- a/serviceproviders.xml
+++ b/serviceproviders.xml
@@ -4526,7 +4526,7 @@ conceived.
 				<usage type="mms"/>
 				<name>Sonera MMS</name>
 				<mmsc>http://mms.sonera.fi:8002</mmsc>
-				<mmsproxy>195.156.25.33:80</mmsproxy>
+				<mmsproxy>195.156.25.33:8080</mmsproxy>
 			</apn>
 		</gsm>
 	</provider>

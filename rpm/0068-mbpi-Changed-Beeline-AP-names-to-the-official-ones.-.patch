 		<gsm>
 			<network-id mcc="250" mnc="28"/>
 			<network-id mcc="250" mnc="44"/>
@@ -10967,16 +10966,14 @@ conceived.
 			<apn value="internet.beeline.ru">
 				<plan type="postpaid"/>
 				<usage type="internet"/>
-				<name>Mobile phone</name>
-				<name xml:lang="ru">Мобильный телефон</name>
+				<name>Beeline Internet</name>
 				<username>beeline</username>
 				<password>beeline</password>
 			</apn>
 			<apn value="home.beeline.ru">
 				<plan type="postpaid"/>
 				<usage type="internet"/>
-				<name>3G modem</name>
-				<name xml:lang="ru">USB-модем</name>
+				<name>Beeline modem</name>
 				<username>beeline</username>
 				<password>beeline</password>
 			</apn>
